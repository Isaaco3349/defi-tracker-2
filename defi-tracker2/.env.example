# Public app configuration
NEXT_PUBLIC_APP_NAME=defi-tracker-2
NEXT_PUBLIC_APP_ENV=development

# Optional RPC / API endpoints (replace with your own if needed)
# These are examples only – do NOT commit real keys or secrets.
NEXT_PUBLIC_GRAVITY_RPC=https://rpc-testnet.gravity.xyz
NEXT_PUBLIC_TEMPO_RPC=https://rpc.moderato.tempo.xyz
NEXT_PUBLIC_ARC_RPC=https://rpc.testnet.arc.network
NEXT_PUBLIC_GIWA_RPC=https://sepolia-rpc.giwa.io
NEXT_PUBLIC_ROBINHOOD_RPC=https://rpc.testnet.chain.robinhood.com

# Example analytics key (public)
NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id-here

# Server-side only secrets should live in `.env.local` (not committed)
# For example:
# DATABASE_URL=postgres://user:password@host:5432/db
# THIRD_PARTY_API_KEY=your-secret-key

